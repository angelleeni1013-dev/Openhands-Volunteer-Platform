@model OpenHandsVolunteerPlatform.ViewModels.VolunteerApplicationsViewModel
@{
    ViewData["Title"] = "My Applications";

    // Get current status from query string
    var currentStatus = Context.Request.Query["status"].ToString().ToLower();
    if (string.IsNullOrEmpty(currentStatus))
    {
        currentStatus = "applied"; // Default tab
    }

    // Get event filter from query string
    var eventFilter = Context.Request.Query["eventFilter"].ToString();
    if (string.IsNullOrEmpty(eventFilter))
    {
        eventFilter = "all"; // Default: show all opportunity
    }
}

<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <!-- ww fix -->
    <h1 class="page-title">My Applications</h1>

    <div class="container-wrapper" style="background-color: #ffffff; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); padding: 2rem;">

        <!-- Page Header with Dual Filters -->
        <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
            @* <h1 class="page-title" style="font-size: 1.8rem; font-weight: 600; color: #1e293b;">My Applications</h1> *@

            <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                <!-- Event Date Status Dropdown (Hamburger Menu) -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="eventFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 12px; padding: 0.6rem 1.2rem; background-color: #f8fafc; border-color: #e2e8f0; color: #1e293b;">
                        <i class="bi bi-calendar3"></i>
                        @{
                            var filterText = eventFilter switch
                            {
                                "upcoming" => "Upcoming Opportunities",
                                "ongoing" => "Ongoing Opportunities",
                                "past" => "Past Opportunities",
                                _ => "All Opportunities"
                            };
                        }
                        @filterText
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" style="border-radius: 12px; padding: 0.5rem; min-width: 180px;">
                        <li>
                            <a class="dropdown-item @(eventFilter == "all" ? "active" : "")"
                               href="@Url.Action("Index", new { status = currentStatus, eventFilter = "all" })"
                               style="border-radius: 8px;">
                               All Opportunities
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item @(eventFilter == "upcoming" ? "active" : "")"
                               href="@Url.Action("Index", new { status = currentStatus, eventFilter = "upcoming" })"
                               style="border-radius: 8px;">
                               Upcoming Opportunities
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item @(eventFilter == "ongoing" ? "active" : "")"
                               href="@Url.Action("Index", new { status = currentStatus, eventFilter = "ongoing" })"
                               style="border-radius: 8px;">
                               Ongoing Opportunities
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item @(eventFilter == "past" ? "active" : "")"
                               href="@Url.Action("Index", new { status = currentStatus, eventFilter = "past" })"
                               style="border-radius: 8px;">
                               Past Opportunities
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Application Status Tabs -->
                <div class="status-tabs" style="display: flex; gap: 0.5rem; background-color: #f8fafc; padding: 0.25rem; border-radius: 12px;">
                    <a href="@Url.Action("Index", new { status = "applied", eventFilter = eventFilter })"
                       class="status-tab @(currentStatus == "applied" ? "active" : "")"
                       style="padding: 0.6rem 1.5rem; border-radius: 10px; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; @(currentStatus == "applied" ? "background-color: #3f4079; color: white;" : "color: #64748b;")">
                        APPLIED
                    </a>
                    <a href="@Url.Action("Index", new { status = "withdrawn", eventFilter = eventFilter })"
                       class="status-tab @(currentStatus == "withdrawn" ? "active" : "")"
                       style="padding: 0.6rem 1.5rem; border-radius: 10px; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; @(currentStatus == "withdrawn" ? "background-color: #3f4079; color: white;" : "color: #64748b;")">
                        WITHDRAWN
                    </a>
                    <a href="@Url.Action("Index", new { status = "removed", eventFilter = eventFilter })"
                       class="status-tab @(currentStatus == "removed" ? "active" : "")"
                       style="padding: 0.6rem 1.5rem; border-radius: 10px; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; @(currentStatus == "removed" ? "background-color: #3f4079; color: white;" : "color: #64748b;")">
                        REMOVED
                    </a>
                </div>
            </div>
        </div>

        <!-- Filter Helper Methods (Add to your ViewModel or Controller) -->
        @{
            var today = DateTime.Now.Date;
            var currentTime = DateTime.Now.TimeOfDay;
            Func<Opportunity, bool> GetEventFilter = (opp) => eventFilter switch
            {
            "upcoming" => opp.Date.Date > today || (opp.Date.Date == today && opp.StartTime > currentTime),
                "ongoing" => opp.Date.Date == today && opp.StartTime <= currentTime && opp.EndTime > currentTime,
                "past" => opp.Date.Date < today || (opp.Date.Date == today && opp.EndTime <= currentTime),
                _ => true
            };
        }

        <hr class="section-divider" style="border: none; border-top: 1px solid #e2e8f0; margin: 1.5rem 0;">

        <!-- Results Count -->
        <div style="margin-bottom: 1.5rem; color: #64748b; font-size: 0.95rem; font-weight: 500;">
            @{
                var count = 0;
                if (currentStatus == "applied")
                {
                    var filteredUpcoming = Model.UpcomingApplications.Where(a => GetEventFilter(a.Opportunity)).ToList();
                    var filteredPast = Model.PastApplications.Where(a => GetEventFilter(a.Opportunity)).ToList();
                    var filteredWaitlist = Model.WaitlistApplications.Where(w => GetEventFilter(w.Application.Opportunity)).ToList();
                    count = filteredUpcoming.Count + filteredPast.Count + filteredWaitlist.Count;
                }
                else if (currentStatus == "withdrawn")
                {
                    count = Model.WithdrawnApplications.Count(a => a.Status == ApplicationStatus.Withdrawn && GetEventFilter(a.Opportunity));
                }
                else if (currentStatus == "removed")
                {
                    count = Model.WithdrawnApplications.Count(a => a.Status == ApplicationStatus.Removed && GetEventFilter(a.Opportunity));
                }
            }
            Showing: @count
        </div>

        <!-- Applications Grid -->
        <div class="opportunity-grid" id="applicationGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; grid-auto-rows: 1fr;">

            @if (currentStatus == "applied")
            {
                <!-- Waitlist Applications First (if any) -->
                @foreach (var item in Model.WaitlistApplications.Where(w => GetEventFilter(w.Application.Opportunity)))
                {
                    <div class="opportunity-card" style="display: flex; flex-direction: column; height: 100%; background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                        <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem; border-bottom: 1px solid #f1f5f9;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                <h3 class="card-title" style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@item.Application.Opportunity.Title</h3>
                                @* <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #fef3c7; color: #92400e;">
                                    WAITLIST
                                </span> *@
                            </div>
                            <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@item.Application.Opportunity.Organization.OrganizationName</div>
                        </div>

                        <div style="flex-grow: 1; padding: 1rem 1.5rem;">
                            <i class="bi bi-geo-alt" style="color: #64748b; display: block; margin-bottom: 1rem;">
                                <span style="margin-left: 0.5rem;">@item.Application.Opportunity.Location</span>
                            </i>

                            <ul class="metadata-list" style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #475569;">
                                    <i class="bi bi-calendar3" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@item.Application.Opportunity.Date.ToString("dd MMM yyyy")</span>
                                </li>
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #475569;">
                                    <i class="bi bi-clock" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@item.Application.Opportunity.StartTime.ToString(@"hh\:mm") - @item.Application.Opportunity.EndTime.ToString(@"hh\:mm")</span>
                                </li>
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; color: #475569;">
                                    <i class="bi bi-person" style="width: 20px; color: #94a3b8;"></i>
                                    <span>Waitlist: @item.WaitlistPosition of @item.TotalWaitlist</span>
                                </li>
                            </ul>
                        </div>

                        <div style="margin-top: auto; padding: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; gap: 0.5rem;">
                            <a asp-area="Volunteer" asp-controller="Opportunities" asp-action="Details" asp-route-id="@item.Application.Opportunity.OpportunityId"
                               class="btn-view-details" style="flex: 1; padding: 0.6rem; text-align: center; background-color: #f8fafc; border-radius: 10px; color: #3f4079; text-decoration: none; font-weight: 500; font-size: 0.9rem; border: 1px solid #e2e8f0;">
                                View Details
                            </a>
                            <form asp-action="Withdraw" asp-route-id="@item.Application.ApplicationId" method="post" style="flex: 1;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-withdraw" onclick="return confirm('Withdraw from waitlist?')"
                                        style="width: 100%; padding: 0.6rem; background-color: #fee2e2; border: 1px solid #fecaca; border-radius: 10px; color: #b91c1c; font-weight: 500; font-size: 0.9rem; cursor: pointer;">
                                    Withdraw
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <!-- Upcoming Applications -->
                @foreach (var application in Model.UpcomingApplications.Where(a => GetEventFilter(a.Opportunity)))
                {
                    <div class="opportunity-card" style="display: flex; flex-direction: column; height: 100%; background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                        <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem; border-bottom: 1px solid #f1f5f9;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start">
                                <h3 class="card-title" style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@application.Opportunity.Title</h3>
                                <!-- Event Date Status Badge (No Withdraw badge) -->
                                @if (application.Opportunity.Date.Date == today && application.Opportunity.StartTime <= currentTime && application.Opportunity.EndTime > currentTime)
                                {
                                    <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #f0f9ff; color: #2c7a7b;">
                                        ONGOING
                                    </span>
                                }
                                else if (application.Opportunity.Date.Date > today || (application.Opportunity.Date.Date == today && application.Opportunity.StartTime > currentTime))
                                {
                                    <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #fef3e7; color: #b85e00;">
                                        UPCOMING
                                    </span>
                                }
                                else if (application.Opportunity.Date.Date < today || (application.Opportunity.Date.Date == today && application.Opportunity.EndTime <= currentTime))
                                {
                                    <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #e8f0fe; color: #1a5a9c;">
                                        PAST
                                    </span>
                                }
                            </div>
                            <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@application.Opportunity.Organization.OrganizationName</div>
                        </div>

                        <div style="flex-grow: 1; padding: 1rem 1.5rem;">
                            <i class="bi bi-geo-alt" style="color: #64748b; display: block; margin-bottom: 1rem;">
                                <span style="margin-left: 0.5rem;">@application.Opportunity.Location</span>
                            </i>

                            <ul class="metadata-list" style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #475569;">
                                    <i class="bi bi-calendar3" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@application.Opportunity.Date.ToString("dd MMM yyyy")</span>
                                </li>
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #475569;">
                                    <i class="bi bi-clock" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@application.Opportunity.StartTime.ToString(@"hh\:mm") - @application.Opportunity.EndTime.ToString(@"hh\:mm")</span>
                                </li>
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; color: #475569;">
                                    <i class="bi bi-people" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@application.Opportunity.VolunteersNeeded volunteers needed</span>
                                </li>
                            </ul>
                        </div>

                        <div style="margin-top: auto; padding: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; gap: 0.5rem;">
                            <a asp-area="Volunteer" asp-controller="Opportunities" asp-action="Details" asp-route-id="@application.Opportunity.OpportunityId"
                               class="btn-view-details" style="flex: 1; padding: 0.6rem; text-align: center; background-color: #f8fafc; border-radius: 10px; color: #3f4079; text-decoration: none; font-weight: 500; font-size: 0.9rem; border: 1px solid #e2e8f0;">
                                View Details
                            </a>
                            @if (application.Opportunity.Date > DateTime.Today.AddDays(1))
                            {
                                <form asp-action="Withdraw" asp-route-id="@application.ApplicationId" method="post" style="flex: 1;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-withdraw" onclick="return confirm('Withdraw from this opportunity?')"
                                            style="width: 100%; padding: 0.6rem; background-color: #fee2e2; border: 1px solid #fecaca; border-radius: 10px; color: #b91c1c; font-weight: 500; font-size: 0.9rem; cursor: pointer;">
                                        Withdraw
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }

                <!-- Past Applications -->
                @foreach (var application in Model.PastApplications.Where(a => GetEventFilter(a.Opportunity)))
                {
                    <div class="opportunity-card" style="display: flex; flex-direction: column; height: 100%; background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; transition: all 0.2s; box-shadow: 0 2px 8px rgba(0,0,0,0.02); opacity: 0.9;">
                        <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem; border-bottom: 1px solid #f1f5f9;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                <h3 class="card-title" style="margin:0; font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@application.Opportunity.Title</h3>
                                <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #e2e8f0; color: #475569;">
                                    PAST
                                </span>
                            </div>
                            <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@application.Opportunity.Organization.OrganizationName</div>
                        </div>

                        <div style="flex-grow: 1; padding: 1rem 1.5rem;">
                            <i class="bi bi-geo-alt" style="color: #64748b; display: block; margin-bottom: 1rem;">
                                <span style="margin-left: 0.5rem;">@application.Opportunity.Location</span>
                            </i>

                            <ul class="metadata-list" style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #475569;">
                                    <i class="bi bi-calendar3" style="width: 20px; color: #94a3b8;"></i>
                                    <span>@application.Opportunity.Date.ToString("dd MMM yyyy")</span>
                                </li>
                                <li class="metadata-item" style="display: flex; align-items: center; gap: 0.5rem; color: #475569;">
                                    <i class="bi bi-check-circle" style="width: 20px; color: #94a3b8;"></i>
                                    <span>Attendance: @application.AttendanceStatus</span>
                                </li>

                                @{
                                    var cert = application.Certificate;
                                }
                                @if (cert != null)
                                {
                                    <li class="metadata-item" style="display:flex; align-items:center; gap:0.5rem;">
                                        <i class="bi bi-award" style="width:20px; color:#f0a500;"></i>
                                        <a href="@cert.PdfPath" target="_blank"
                                           style="color:#f0a500; font-weight:600; font-size:0.85rem; text-decoration:none;">
                                            <i class="bi bi-download"></i> View Certificate
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div style="padding: 1rem 1.5rem 1.5rem 1.5rem; border-top: 1px solid #f1f5f9;">
                            <a asp-area="Volunteer" asp-controller="Opportunities" asp-action="Details" asp-route-id="@application.Opportunity.OpportunityId"
                               class="btn-view-details"
                               style="display: block; padding: 0.6rem; text-align: center; background-color: #f8fafc; border-radius: 10px; color: #3f4079; text-decoration: none; font-weight: 500; font-size: 0.9rem; border: 1px solid #e2e8f0;">
                                View Details
                            </a>

                            @if (application.AttendanceStatus == AttendanceStatus.Present)
                            {
                                <a asp-area="Volunteer" asp-controller="Rating" asp-action="RateOrganization"
                                   asp-route-organizationId="@application.Opportunity.Organization.OrganizationId"
                                   asp-route-opportunityId="@application.Opportunity.OpportunityId"
                                   style="display:block; margin-top:0.5rem; padding:0.6rem; text-align:center; background-color:#f0f2ff;
                                               border-radius:10px; color:#8b92d1; text-decoration:none; font-weight:500;
                                               font-size:0.9rem; border:1px solid #d8ddff;">
                                    <i class="bi bi-star"></i> Rate Organization
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else if (currentStatus == "withdrawn")
            {
                <!-- Withdrawn Applications -->
                @foreach (var application in Model.WithdrawnApplications.Where(a => a.Status == ApplicationStatus.Withdrawn && GetEventFilter(a.Opportunity)))
                {
                    <div class="opportunity-card" style="display: flex; flex-direction: column; height: 100%; background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; opacity: 0.8;">
                        <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                <h3 class="card-title" style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@application.Opportunity.Title</h3>
                                @* <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #f1f5f9; color: #64748b;">
                                    WITHDRAWN
                                </span> *@
                            </div>
                            <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@application.Opportunity.Organization.OrganizationName</div>
                            <div style="margin-top: 0.5rem; font-size: 0.85rem; color: #94a3b8;">
                                Withdrawn on @(application.WithdrawnAt?.ToString("dd MMM yyyy") ?? application.AppliedAt.ToString("dd MMM yyyy"))
                            </div>
                        </div>
                    </div>
                }
            }
            else if (currentStatus == "removed")
            {
                <!-- Removed Applications -->
                @foreach (var application in Model.WithdrawnApplications.Where(a => a.Status == ApplicationStatus.Removed && GetEventFilter(a.Opportunity)))
                {
                    <div class="opportunity-card" style="display: flex; flex-direction: column; height: 100%; background: white; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; opacity: 0.8;">
                        <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                <h3 class="card-title" style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@application.Opportunity.Title</h3>
                                @* <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; background-color: #fee2e2; color: #b91c1c;">
                                    REMOVED
                                </span> *@
                            </div>
                            <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@application.Opportunity.Organization.OrganizationName</div>
                            <div style="margin-top: 0.5rem; font-size: 0.85rem; color: #94a3b8;">
                                Removed by organization
                            </div>
                        </div>
                    </div>
                }
            }

            <!-- Empty states remain the same -->
            @if ((currentStatus == "applied" && !Model.UpcomingApplications.Any() && !Model.WaitlistApplications.Any() && !Model.PastApplications.Any()) ||
                        (currentStatus == "withdrawn" && !Model.WithdrawnApplications.Any(a => a.Status == ApplicationStatus.Withdrawn)) ||
                        (currentStatus == "removed" && !Model.WithdrawnApplications.Any(a => a.Status == ApplicationStatus.Removed)))
            {
                <div class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; background: #f8fafc; border-radius: 20px;">
                    <h3 style="margin: 1rem 0 0.5rem; color: #334155;">No @currentStatus applications</h3>
                    <p style="color: #64748b;">There are no @currentStatus applications to display.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            var searchTerm = this.value.toLowerCase();
            var cards = document.querySelectorAll('.opportunity-card');

            cards.forEach(function(card) {
                var title = card.querySelector('.card-title')?.innerText.toLowerCase() || '';
                var org = card.querySelector('.card-subtitle')?.innerText.toLowerCase() || '';
                var location = card.innerText.toLowerCase();

                if (title.includes(searchTerm) || org.includes(searchTerm) || location.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });

        // Auto-refresh waitlist positions every 30 seconds
        @if (currentStatus == "applied" && Model.WaitlistApplications.Any())
        {
                <text>
                setInterval(function() {
                    // Find all waitlist cards and update positions via AJAX
                }, 30000);
                </text>
        }
    </script>
}