@model OpenHandsVolunteerPlatform.Models.Application
@{
    ViewData["Title"] = "Withdraw Application";
}

<div class="container mt-4">
    <div class="container-wrapper" style="background-color: #ffffff; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); padding: 2rem; max-width: 600px; margin: 0 auto;">

        <!-- Page Header -->
        <div class="page-header" style="margin-bottom: 2rem;">
            <h1 class="page-title" style="font-size: 1.8rem; font-weight: 600; color: #1e293b;">Withdraw Application</h1>
            <p style="color: #64748b; margin-top: 0.5rem;">Please review the details below before withdrawing.</p>
        </div>

        <!-- Opportunity Card (Summary) -->
        <div class="opportunity-card" style="background: #f8fafc; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 2rem;">
            <div class="card-header" style="padding: 1.5rem 1.5rem 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                    <h3 class="card-title" style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0;">@Model.Opportunity.Title</h3>
                    <span class="status-badge" style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;
                        @(Model.Status == ApplicationStatus.Applied ? "background-color: #dcfce7; color: #166534;" :
                                                                         Model.Status == ApplicationStatus.Waitlist ? "background-color: #fef3c7; color: #92400e;" : "")">
                        @Model.Status
                    </span>
                </div>
                <div class="card-subtitle" style="color: #64748b; font-size: 0.9rem;">@Model.Opportunity.Organization.OrganizationName</div>
            </div>

            <div style="padding: 1.5rem;">
                <ul class="metadata-list" style="list-style: none; padding: 0; margin: 0;">
                    <li class="metadata-item" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; color: #475569;">
                        <i class="bi bi-calendar3" style="width: 20px; color: #94a3b8;"></i>
                        <span>@Model.Opportunity.Date.ToString("dddd, MMMM d, yyyy")</span>
                    </li>
                    <li class="metadata-item" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; color: #475569;">
                        <i class="bi bi-clock" style="width: 20px; color: #94a3b8;"></i>
                        <span>@Model.Opportunity.StartTime.ToString(@"hh\:mm") - @Model.Opportunity.EndTime.ToString(@"hh\:mm")</span>
                    </li>
                    <li class="metadata-item" style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; color: #475569;">
                        <i class="bi bi-geo-alt" style="width: 20px; color: #94a3b8;"></i>
                        <span>@Model.Opportunity.Location</span>
                    </li>
                    <li class="metadata-item" style="display: flex; align-items: center; gap: 0.75rem; color: #475569;">
                        <i class="bi bi-file-text" style="width: 20px; color: #94a3b8;"></i>
                        <span>Applied on: @Model.AppliedAt.ToString("MMMM d, yyyy")</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Warning Message -->
        <div class="alert alert-warning" style="background-color: #fef3c7; border: 1px solid #fde68a; border-radius: 12px; padding: 1rem; margin-bottom: 2rem; display: flex; align-items: flex-start; gap: 0.75rem;">
            <i class="bi bi-exclamation-triangle-fill" style="color: #92400e; font-size: 1.25rem;"></i>
            <div>
                <strong style="color: #92400e; display: block; margin-bottom: 0.25rem;">Warning: This action cannot be undone</strong>
                <p style="color: #92400e; margin: 0; font-size: 0.9rem;">
                    Withdrawing will remove you from this opportunity.
                    @if (Model.Status == ApplicationStatus.Applied)
                    {
                        <span>Your spot will be offered to the next person on the waitlist.</span>
                    }
                    else if (Model.Status == ApplicationStatus.Waitlist)
                    {
                        <span>Your waitlist position will be lost.</span>
                    }
                </p>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons" style="display: flex; gap: 1rem;">
            <a asp-action="Index" asp-controller="Application"
               class="btn-cancel"
               style="flex: 1; padding: 0.75rem; text-align: center; background-color: #f8fafc; border-radius: 12px; color: #64748b; text-decoration: none; font-weight: 500; font-size: 1rem; border: 1px solid #e2e8f0; transition: all 0.2s;">
                Cancel
            </a>

            <!-- Single form with JavaScript confirmation -->
            <form asp-action="Withdraw" asp-route-id="@Model.ApplicationId" method="post"
                  id="withdrawForm" style="flex: 1;"
                  onsubmit="return confirmWithdraw(event, '@Model.Status')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-withdraw-confirm"
                        style="width: 100%; padding: 0.75rem; background-color: #ef4444; border: none; border-radius: 12px; color: white; font-weight: 500; font-size: 1rem; cursor: pointer; transition: all 0.2s;"
                        onmouseover="this.style.backgroundColor='#dc2626'"
                        onmouseout="this.style.backgroundColor='#ef4444'">
                    Yes, Withdraw
                </button>
            </form>
        </div>

        <!-- Additional Info -->
        <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #e2e8f0;">
            <p style="color: #94a3b8; font-size: 0.85rem; margin: 0;">
                <i class="bi bi-info-circle"></i>
                If you change your mind, you'll need to reapply for this opportunity. However, you may be placed on the waitlist if the opportunity is full.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmWithdraw(event, status) {
            event.preventDefault();

            let message = 'Are you sure you want to withdraw from this opportunity?\n\n';

            if (status === 'Applied') {
                message += 'Your spot will be offered to the next person on the waitlist.';
            } else if (status === 'Waitlist') {
                message += 'Your waitlist position will be lost.';
            }

            if (confirm(message)) {
                document.getElementById('withdrawForm').submit();
            }

            return false;
        }
    </script>
}