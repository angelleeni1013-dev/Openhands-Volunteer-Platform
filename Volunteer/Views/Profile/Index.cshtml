@* By WW *@

@model OpenHandsVolunteerPlatform.ViewModels.VolProfileViewModel
@using OpenHandsVolunteerPlatform.Models.Enums

@{
    ViewData["Title"] = "Volunteer Profile";
}

<link rel="stylesheet" href="~/css/VolProfile.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">


<div class="main-container">
    @* <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    } *@

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="bi bi-person-circle"></i>
        </div>

        <div class="profile-title">
            <h1>@Model.Name</h1>

            <div class="profile-location">
                <i class="bi bi-envelope"></i>
                <span>@Model.Email</span>
            </div>

            <div class="profile-badges">
                <span class="verification-badge" style="background: #f0f2ff; color: #3f4079;">
                    <i class="bi bi-person"></i> Volunteer
                </span>

                <span class="verification-badge @Model.CreditLevelClass">
                    <i class="bi bi-star-fill"></i> @Model.CreditLevelDisplay
                </span>
            </div>
        </div>

        <!-- Edit button on the right -->
        <div style="margin-left: auto;">
            <a href="@Url.Action("Edit")" class="btn-edit-profile">
                <i class="bi bi-pencil-square"></i> Edit Profile
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-number">@Model.CompletedEvents</div>
            <div class="stat-label">Completed Events</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.TotalHours</div>
            <div class="stat-label">Total Hours</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.AppliedCount</div>
            <div class="stat-label">Applied</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.WaitlistCount</div>
            <div class="stat-label">Waitlist</div>
        </div>
    </div>

    <!-- Info Grid -->
    <div class="info-grid">
        <!-- Personal Information -->
        <div class="info-card">
            <div class="info-card-title">
                <i class="bi bi-person"></i> Personal Information
            </div>

            <div class="info-row">
                <span class="info-label">Age:</span>
                <span class="info-value">@Model.Age years old</span>
            </div>

            <div class="info-row">
                <span class="info-label">Phone:</span>
                <span class="info-value">@Model.Phone</span>
            </div>

            <div class="info-row">
                <span class="info-label">Availability:</span>
                <span class="info-value">@Model.AvailabilityDisplay</span>
            </div>

            <div class="info-row">
                <span class="info-label">Member Since:</span>
                <span class="info-value">@Model.JoinedDate.ToString("dd MMMM yyyy")</span>
            </div>
        </div>

        <!-- Credit Score Details -->
        <div class="info-card">
            <div class="info-card-title">
                <i class="bi bi-star-fill"></i> Credit Score Details
            </div>

            <div class="info-row">
                <span class="info-label">Current Level:</span>
                <span class="info-value">
                    <span class="credit-badge @Model.CreditLevelClass">@Model.CreditLevelDisplay</span>
                </span>
            </div>

            <div class="info-row">
                <span class="info-label">Completed:</span>
                <span class="info-value">@Model.CompletedEvents events</span>
            </div>

            <div class="info-row">
                <span class="info-label">No-Shows:</span>
                <span class="info-value">@Model.NoShowCount</span>
            </div>

            <div class="info-row">
                <span class="info-label">Last Active:</span>
                <span class="info-value">
                    @(Model.LastActiveDate?.ToString("dd MMM yyyy") ?? "Not yet")
                </span>
            </div>
        </div>
    </div>

    <!-- Next Milestone Card -->
    <div class="mission-card">
        <div class="info-card-title">
            <i class="bi bi-graph-up"></i> Next Milestone
        </div>

        <div class="mission-text">
            @Model.NextMilestone
        </div>

        <!-- Progress bar -->
        <div style="margin-top: 1rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; color: #64748b;">
                <span>Progress</span>
                <span>@Model.ProgressToNextMilestone%</span>
            </div>
            <div style="height: 8px; background: #e9ecf3; border-radius: 4px; overflow: hidden;">
                <div style="height: 100%; width: @Model.ProgressToNextMilestone%; background: linear-gradient(90deg, #8b92d1, #5f61a9); border-radius: 4px;"></div>
            </div>
        </div>

        <div style="margin-top: 1.5rem; text-align: right;">
            <button class="btn-edit-profile" onclick="viewCreditHistory()" style="background: #f0f2ff; color: #3f4079; border: none;">
                <i class="bi bi-clock-history"></i> View Credit History
            </button>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="document-card">
        <div class="info-card-title">
            <i class="bi bi-grid"></i> Quick Actions
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
            <a href="@Url.Action("Index", "Opportunities")" class="action-link">
                <i class="bi bi-calendar-event"></i>
                <span>Browse Opportunities</span>
            </a>
            <a href="@Url.Action("Index", "Application")" class="action-link">
                <i class="bi bi-card-list"></i>
                <span>My Applications</span>
            </a>
            <a href="#" class="action-link" onclick="viewCreditHistory()">
                <i class="bi bi-star"></i>
                <span>Credit History</span>
            </a>
        </div>
    </div>

    <!-- Footer -->
    <div class="profile-footer">
        <i class="bi bi-calendar3"></i> Member since @Model.JoinedDate.ToString("MMMM yyyy")
    </div>
</div>

<!-- Credit History Modal -->
<div class="modal fade" id="creditHistoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div id="creditHistoryModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden field for anti-forgery token -->
@Html.AntiForgeryToken()

<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function viewCreditHistory() {
        const modal = new bootstrap.Modal(document.getElementById('creditHistoryModal'));
        const modalBody = document.getElementById('creditHistoryModalBody');

        modalBody.innerHTML = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        `;

        modal.show();

        fetch('/Volunteer/Profile/CreditHistory')
            .then(response => response.text())
            .then(html => {
                modalBody.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                modalBody.innerHTML = `
                    <div class="alert alert-danger">
                        Error loading credit history. Please try again.
                    </div>
                `;
            });
    }
</script>
