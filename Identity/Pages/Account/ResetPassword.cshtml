@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="min-height:60vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="background:white; border-radius:24px; padding:2.5rem 2rem;
                max-width:440px; width:100%;
                box-shadow:0 8px 32px rgba(63,64,121,0.10);">

        <div style="text-align:center; margin-bottom:1.5rem;">
            <div style="width:64px; height:64px; background:#f0f2ff; border-radius:50%;
                        display:inline-flex; align-items:center; justify-content:center;
                        border:2px solid #e0e4ff;">
                <i class="bi bi-shield-lock" style="font-size:1.8rem; color:#6366f1;"></i>
            </div>
        </div>

        <h2 style="text-align:center; color:#3f4079; font-weight:700;
                   font-size:1.4rem; margin-bottom:0.5rem;">
            Set New Password
        </h2>
        <p style="text-align:center; color:#8e94a7; font-size:0.9rem; margin-bottom:1.75rem;">
            Choose a strong password for your account.
        </p>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"
                 style="font-size:0.85rem;"></div>

            @* Hidden fields — carry email and token from the reset link *@
            <input asp-for="Code" type="hidden" />
            <input asp-for="Email" type="hidden" />

            <div style="margin-bottom:1.25rem;">
                <label style="font-weight:600; font-size:0.8rem; color:#3f4079;
                              text-transform:uppercase; letter-spacing:0.5px;
                              display:block; margin-bottom:0.4rem;">
                    New Password
                </label>
                <input asp-for="Password"
                       class="form-control"
                       placeholder="Enter new password"
                       style="border-radius:10px; border:1.5px solid #d5d8e8;
                              padding:0.7rem 1rem; font-size:0.95rem;" />
            </div>

            <div style="margin-bottom:1.5rem;">
                <label style="font-weight:600; font-size:0.8rem; color:#3f4079;
                              text-transform:uppercase; letter-spacing:0.5px;
                              display:block; margin-bottom:0.4rem;">
                    Confirm New Password
                </label>
                <input asp-for="ConfirmPassword"
                       class="form-control"
                       placeholder="Confirm new password"
                       style="border-radius:10px; border:1.5px solid #d5d8e8;
                              padding:0.7rem 1rem; font-size:0.95rem;" />
            </div>

            <button type="submit"
                    style="background:#6366f1; color:white; border:none; border-radius:50px;
                           padding:0.85rem 0; width:100%; font-size:1rem; font-weight:700;
                           cursor:pointer; letter-spacing:0.5px;
                           box-shadow:0 4px 14px rgba(99,102,241,0.3);">
                Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}