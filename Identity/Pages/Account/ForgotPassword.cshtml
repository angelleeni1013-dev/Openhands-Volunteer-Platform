@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="min-height:60vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="background:white; border-radius:24px; padding:2.5rem 2rem;
                max-width:440px; width:100%;
                box-shadow:0 8px 32px rgba(63,64,121,0.10);">

        <div style="text-align:center; margin-bottom:1.5rem;">
            <div style="width:64px; height:64px; background:#f0f2ff; border-radius:50%;
                        display:inline-flex; align-items:center; justify-content:center;
                        border:2px solid #e0e4ff;">
                <i class="bi bi-lock" style="font-size:1.8rem; color:#6366f1;"></i>
            </div>
        </div>

        <h2 style="text-align:center; color:#3f4079; font-weight:700;
                   font-size:1.4rem; margin-bottom:0.5rem;">
            Forgot Password?
        </h2>
        <p style="text-align:center; color:#8e94a7; font-size:0.9rem; margin-bottom:1.75rem;">
            Enter your email and we'll send you a reset link.
        </p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"
                 style="font-size:0.85rem;"></div>

            <div style="margin-bottom:1.25rem;">
                <label asp-for="Email"
                       style="font-weight:600; font-size:0.8rem; color:#3f4079;
                              text-transform:uppercase; letter-spacing:0.5px;
                              display:block; margin-bottom:0.4rem;">
                    Email Address
                </label>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="yourname@tmails.net"
                       style="border-radius:10px; border:1.5px solid #d5d8e8;
                              padding:0.7rem 1rem; font-size:0.95rem;" />
                <span asp-validation-for="Email" class="text-danger"
                      style="font-size:0.8rem;"></span>
            </div>

            <button type="submit"
                    style="background:#6366f1; color:white; border:none; border-radius:50px;
                           padding:0.85rem 0; width:100%; font-size:1rem; font-weight:700;
                           cursor:pointer; letter-spacing:0.5px;
                           box-shadow:0 4px 14px rgba(99,102,241,0.3);">
                Send Reset Link
            </button>

            <p style="text-align:center; margin-top:1.25rem; font-size:0.9rem; color:#8e94a7;">
                Remember your password?
                <a asp-page="./Login"
                   style="color:#6366f1; font-weight:600; text-decoration:none;">
                    Back to Login
                </a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}