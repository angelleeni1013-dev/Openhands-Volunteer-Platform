@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="min-height:60vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="background:white; border-radius:24px; padding:2.5rem 2rem;
                max-width:440px; width:100%; text-align:center;
                box-shadow:0 8px 32px rgba(63,64,121,0.10);">

        <!-- Icon -->
        <div style="width:72px; height:72px; background:#f0f2ff; border-radius:50%;
                    display:inline-flex; align-items:center; justify-content:center;
                    border:2px solid #e0e4ff; margin-bottom:1.25rem;">
            <i class="bi bi-envelope-check" style="font-size:2rem; color:#6366f1;"></i>
        </div>

        <h2 style="color:#3f4079; font-weight:700; font-size:1.4rem; margin-bottom:0.5rem;">
            Check Your Email
        </h2>

        <p style="color:#5a5f7d; font-size:0.95rem; line-height:1.6; margin-bottom:1.5rem;">
            If an account with that email exists, we've sent a password reset link.
            Please check your inbox and spam folder.
        </p>

        <!-- Info box -->
        <div style="background:#f5f7ff; border:1px solid #e0e4ff; border-radius:14px;
                    padding:1rem 1.25rem; text-align:left; margin-bottom:1.75rem;">
            <div style="display:flex; gap:0.6rem; align-items:flex-start;">
                <i class="bi bi-info-circle" style="color:#6366f1; flex-shrink:0; margin-top:2px;"></i>
                <p style="color:#4b5073; font-size:0.85rem; line-height:1.55; margin:0;">
                    The reset link will expire in <strong>24 hours</strong>.
                    If you don't receive an email within a few minutes, check your spam folder or
                    <a asp-page="./ForgotPassword" style="color:#6366f1;">try again</a>.
                </p>
            </div>
        </div>

        <a asp-page="./Login"
           style="display:block; background:#6366f1; color:white; border-radius:50px;
                  padding:0.85rem 0; font-size:1rem; font-weight:700;
                  text-decoration:none; letter-spacing:0.5px;
                  box-shadow:0 4px 14px rgba(99,102,241,0.3);">
            Back to Login
        </a>
    </div>
</div>