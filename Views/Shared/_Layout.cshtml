    <!--By WW-->
    @if (User.IsInRole("Volunteer"))
    {
        <script>
            async function loadNotifications() {
                try {
                    const res = await fetch('/Volunteer/Notifications/GetDropdown');
                    if (!res.ok) return;
                    const data = await res.json();

                    const badge = document.getElementById('notif-badge');
                    const empty = document.getElementById('notif-empty');
                    const list = document.getElementById('notif-dropdown-list');

                    const oldItems = list.querySelectorAll('.notif-item');
                    oldItems.forEach(i => i.remove());

                    if (data.unreadCount > 0) {
                        badge.style.display = 'flex';
                        badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
                        empty.style.display = 'none';

                        data.notifications.forEach(n => {
                            const li = document.createElement('li');
                            li.className = 'notif-item';
                            li.style = 'padding:0.75rem 1rem; border-bottom:1px solid #f5f5f5; background:' + (n.isRead ? 'white' : '#f5f7ff');
                            li.innerHTML = `
                                <div style="font-size:0.85rem; color:#2d3e4f; font-weight:${n.isRead ? '400' : '600'}">
                                    ${n.message}
                                </div>
                                <div style="font-size:0.75rem; color:#8e94a7; margin-top:0.2rem">${n.createdAt}</div>
                            `;
                            list.appendChild(li);
                        });
                    } else {
                        badge.style.display = 'none';
                        empty.style.display = 'block';
                    }
                } catch (e) {
                    console.log('Notification load failed', e);
                }
            }

            document.addEventListener('DOMContentLoaded', loadNotifications);
        </script>
    }
