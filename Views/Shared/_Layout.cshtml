    <!-- WW FIX AI CHATBOT -->
    @if (User.IsInRole("Organization"))
    {
        <!-- Chat Button -->
        <div class="chat-btn" onclick="toggleChat()">
            <i class="bi bi-chat-dots-fill"></i>
        </div>

        <!-- Chat Window -->
        <div class="chat-window" id="chatWindow">
            <div class="chat-header">
                <span><i class="bi bi-robot"></i> OpenHands Assistant</span>
                <button onclick="toggleChat()" style="background:none; border:none; color:white; cursor:pointer;">✕</button>
            </div>
            <div class="chat-messages" id="chatMessages">
                <div class="message bot">
                    <div class="message-content">
                        👋 Hi! I'm the <b>OpenHands AI Opportunity Creator</b><br><br>
                        Describe your volunteer opportunity and I'll help you create it!<br><br>
                        <em>💡 Try: "Health Charity Marathon, charity run corporate with CHAGEE need 50 volunteers tomorrow from 9AM to 12PM at SPICE Arena"</em>
                    </div>
                </div>
            </div>
            <div class="chat-input">
                <textarea id="chatInput" placeholder="Type your opportunity description..." rows="1"></textarea>
                <button onclick="sendChat()">Send</button>
            </div>
        </div>
        <script>
            // WW FIX AI CHATBOT SCRIPT
            let lastExtractedData = null;

            // Clear session AND UI when page loads
            window.addEventListener('load', function() {
                // Reset server session
                fetch('/api/chat/reset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                }).catch(err => console.log('Reset error:', err));

                // Clear local stored data
                lastExtractedData = null;

                // Reset the chat UI to initial state
                const container = document.getElementById('chatMessages');
                if (container) {
                    container.innerHTML = `
                        <div class="message bot">
                            <div class="message-content">
                                👋 Hi! I'm the <b>OpenHands AI Opportunity Creator</b><br><br>
                                Describe your volunteer opportunity and I'll help you create it!<br><br>
                                <em>💡 Try: "Need 50 volunteers for Health Charity Marathon Event tomorrow from 9AM to 12PM at SPICE Arena Penang"</em>
                            </div>
                        </div>
                    `;
                }

                console.log('Chat session and UI reset on page load');
            });

            function toggleChat() {
                document.getElementById('chatWindow').classList.toggle('open');
            }

            function addMessage(text, sender) {
                const container = document.getElementById('chatMessages');
                const div = document.createElement('div');
                div.className = `message ${sender}`;
                div.innerHTML = `<div class="message-content">${text}</div>`;
                container.appendChild(div);
                container.scrollTop = container.scrollHeight;
            }

            async function sendChat() {
                const input = document.getElementById('chatInput');
                const message = input.value.trim();
                if (!message) return;

                // Clear input
                input.value = '';
                input.style.height = '36px';
                input.style.overflowY = 'hidden';

                addMessage(message, 'user');
                showTyping();

                try {
                    const response = await fetch('/api/chat/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: message })
                    });

                    const data = await response.json();
                    hideTyping();

                    // Add AI response to chat
                    addMessage(data.reply, 'bot');

                    // Store extracted data
                    if (data.extracted && Object.keys(data.extracted).length > 0) {
                        lastExtractedData = data.extracted;
                        console.log('Extracted data:', lastExtractedData);

                        // Check if all required fields are present
                        if (lastExtractedData.Volunteers &&
                            lastExtractedData.Date &&
                            lastExtractedData.StartTime &&
                            lastExtractedData.EndTime &&
                            lastExtractedData.Location) {
                            showCreateOpportunityButton();
                        }
                    }

                    // If data.isComplete flag is true from server, also show button
                    if (data.isComplete) {
                        showCreateOpportunityButton();
                    }

                } catch (error) {
                    hideTyping();
                    console.error('Error:', error);
                    addMessage('Sorry, I\'m having trouble connecting. Please try again.', 'bot');
                }
            }

            function showCreateOpportunityButton() {
                const existingBtn = document.getElementById('createOpportunityBtn');
                if (existingBtn) existingBtn.remove();

                const container = document.getElementById('chatMessages');
                const buttonDiv = document.createElement('div');
                buttonDiv.className = 'message bot';
                buttonDiv.id = 'createOpportunityBtn';
                buttonDiv.innerHTML = `
                    <div class="message-content" style="background: #e0e4ff; text-align: center;">
                        <button onclick="createOpportunity()" style="background: #8b92d1; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">
                            ➕ Create Opportunity
                        </button>
                    </div>
                `;
                container.appendChild(buttonDiv);
                container.scrollTop = container.scrollHeight;
            }

            async function createOpportunity() {
                if (!lastExtractedData) {
                    console.error('No extracted data available');
                    return;
                }

                console.log('Creating opportunity with data:', JSON.stringify(lastExtractedData, null, 2));

                // Get title
                let title = '';
                if (lastExtractedData.Title && lastExtractedData.Title !== 'null' && lastExtractedData.Title.trim() !== '') {
                    title = lastExtractedData.Title;
                } else {
                    title = 'New Volunteer Opportunity';
                }

                // Show loading message immediately
                const loadingMsgId = 'generatingDescMsg';
                const existingLoadingMsg = document.getElementById(loadingMsgId);
                if (existingLoadingMsg) existingLoadingMsg.remove();

                const loadingDiv = document.createElement('div');
                loadingDiv.id = loadingMsgId;
                loadingDiv.className = 'message bot';
                loadingDiv.innerHTML = `
                    <div class="message-content" style="background: #e0e4ff;">
                        <i class="bi bi-hourglass-split"></i> 🤖 AI is generating a professional description for your opportunity... Please wait.
                    </div>
                `;
                const container = document.getElementById('chatMessages');
                container.appendChild(loadingDiv);
                container.scrollTop = container.scrollHeight;

                let description = '';

                try {
                    // Generate description using LLM
                    const promptData = {
                        title: title,
                        volunteers: lastExtractedData.Volunteers || 'dedicated',
                        isEmergency: lastExtractedData.IsEmergency === 'true' || lastExtractedData.IsEmergency === true
                    };

                    const descResponse = await fetch('/api/chat/generate-description', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(promptData)
                    });

                    const descData = await descResponse.json();
                    description = descData.description;

                    console.log('Generated description:', description);

                    // Remove loading message
                    const loadingMsg = document.getElementById(loadingMsgId);
                    if (loadingMsg) loadingMsg.remove();

                } catch (error) {
                    console.error('Error generating description:', error);
                    // Remove loading message
                    const loadingMsg = document.getElementById(loadingMsgId);
                    if (loadingMsg) loadingMsg.remove();

                    // Simple fallback
                    if (lastExtractedData.IsEmergency === 'true' || lastExtractedData.IsEmergency === true) {
                        description = `🚨 URGENT: Join us for ${title}! We need volunteers immediately. Sign up now!`;
                    } else {
                        description = `✨ Join us for ${title}! We're looking for volunteers to help out. No experience needed. Sign up now and make a difference!`;
                    }
                }

                // Build URL parameters
                const params = new URLSearchParams();

                params.append('title', title);
                params.append('description', description);

                if (lastExtractedData.Volunteers && lastExtractedData.Volunteers !== 'null') {
                    params.append('volunteers', lastExtractedData.Volunteers);
                }

                if (lastExtractedData.Date && lastExtractedData.Date !== 'null') {
                    params.append('date', lastExtractedData.Date);
                }

                if (lastExtractedData.ApplicationCloseDate && lastExtractedData.ApplicationCloseDate !== 'null') {
                    params.append('applicationCloseDate', lastExtractedData.ApplicationCloseDate);
                }

                if (lastExtractedData.StartTime && lastExtractedData.StartTime !== 'null') {
                    let startTime = lastExtractedData.StartTime.toString().trim();
                    startTime = convertTo24Hour(startTime);
                    params.append('startTime', startTime);
                }

                if (lastExtractedData.EndTime && lastExtractedData.EndTime !== 'null') {
                    let endTime = lastExtractedData.EndTime.toString().trim();
                    endTime = convertTo24Hour(endTime);
                    params.append('endTime', endTime);
                }

                if (lastExtractedData.Location && lastExtractedData.Location !== 'null') {
                    params.append('location', lastExtractedData.Location);
                }

                if (lastExtractedData.IsEmergency === 'true' || lastExtractedData.IsEmergency === true) {
                    params.append('isEmergency', 'true');
                    params.append('minimumCreditLevel', '2');
                    console.log('Emergency mode enabled - Credit level set to: Growing and Above');
                }

                const redirectUrl = `/Organization/Opportunity/Create?${params.toString()}`;
                console.log('FULL URL:', redirectUrl);

                window.location.href = redirectUrl;
            }

            // Helper function to convert 24-hour time to 12-hour display format
            function formatTimeForDisplay(timeStr) {
                if (!timeStr) return '';

                let hour = 0;
                let minute = 0;

                if (timeStr.includes(':')) {
                    const parts = timeStr.split(':');
                    hour = parseInt(parts[0]);
                    minute = parseInt(parts[1]);
                } else {
                    hour = parseInt(timeStr);
                }

                const period = hour >= 12 ? 'PM' : 'AM';
                let displayHour = hour % 12;
                if (displayHour === 0) displayHour = 12;

                if (minute > 0) {
                    return `${displayHour}:${minute.toString().padStart(2, '0')} ${period}`;
                }
                return `${displayHour} ${period}`;
            }

            // Helper function to convert time to 24-hour format
            function convertTo24Hour(timeStr) {
                if (!timeStr) return '';

                let cleanTime = timeStr.toString().trim();

                // If already in HH:MM format (24-hour), return as is
                if (/^([01]\d|2[0-3]):([0-5]\d)$/.test(cleanTime)) {
                    return cleanTime;
                }

                // Check if it's AM or PM
                let isPM = /pm/i.test(cleanTime);
                let hour = 0;
                let minute = 0;
                let numbers = cleanTime.match(/\d+/g);

                if (numbers) {
                    hour = parseInt(numbers[0]);
                    minute = numbers[1] ? parseInt(numbers[1]) : 0;
                }

                // Convert to 24-hour format
                if (isPM && hour === 12) {
                    hour = 12;
                } else if (isPM && hour < 12) {
                    hour += 12;
                } else if (!isPM && hour === 12) {
                    hour = 0;
                }

                return `${hour.toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')}`;
            }

            function showTyping() {
                const container = document.getElementById('chatMessages');
                const typing = document.createElement('div');
                typing.className = 'message bot';
                typing.id = 'typingIndicator';
                typing.innerHTML = `<div class="typing-indicator"><span></span><span></span><span></span></div>`;
                container.appendChild(typing);
                container.scrollTop = container.scrollHeight;
            }

            function hideTyping() {
                const indicator = document.getElementById('typingIndicator');
                if (indicator) indicator.remove();
            }

            // Auto-resize textarea and Enter key handling
            document.addEventListener('DOMContentLoaded', function() {
                const chatInput = document.getElementById('chatInput');
                if (chatInput) {
                    chatInput.addEventListener('input', function() {
                        this.style.height = 'auto';
                        const newHeight = Math.min(this.scrollHeight, 100);
                        this.style.height = newHeight + 'px';
                        this.style.overflowY = this.scrollHeight > 100 ? 'auto' : 'hidden';
                    });
                    chatInput.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter' && !e.shiftKey) {
                            e.preventDefault();
                            sendChat();
                        }
                    });
                }
            });
        </script>
    }



    <!--By ANGEL-->
    <!-- Simple dropdown fix -->
    <script>
        // Force Bootstrap to reinitialize on every page
        document.addEventListener('DOMContentLoaded', function() {
            // Trigger Bootstrap's initialization
            if (typeof bootstrap !== 'undefined') {
                // This forces Bootstrap to scan the DOM again
                document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(function(element) {
                    new bootstrap.Dropdown(element);
                });
            }
        });

        // Manual toggle as backup
        document.addEventListener('click', function(e) {
            var toggle = e.target.closest('[data-bs-toggle="dropdown"]');
            if (toggle) {
                e.preventDefault();
                e.stopPropagation();

                var menu = toggle.nextElementSibling;
                if (menu && menu.classList.contains('dropdown-menu')) {
                    // Close all other dropdowns
                    document.querySelectorAll('.dropdown-menu.show').forEach(function(m) {
                        if (m !== menu) {
                            m.classList.remove('show');
                            var t = m.previousElementSibling;
                            if (t && t.hasAttribute('aria-expanded')) {
                                t.setAttribute('aria-expanded', 'false');
                            }
                        }
                    });

                    // Toggle current dropdown
                    menu.classList.toggle('show');
                    var expanded = toggle.getAttribute('aria-expanded') === 'true' ? 'false' : 'true';
                    toggle.setAttribute('aria-expanded', expanded);
                }
            }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.dropdown')) {
                document.querySelectorAll('.dropdown-menu.show').forEach(function(menu) {
                    menu.classList.remove('show');
                    var toggle = menu.previousElementSibling;
                    if (toggle && toggle.hasAttribute('aria-expanded')) {
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });

        // Fix By WW
        // Simple active page highlighting
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname.toLowerCase();

            // Get the current controller name from the URL
            const pathParts = currentPath.split('/').filter(p => p);
            const currentArea = pathParts.length >= 1 ? pathParts[0] : '';
            const currentController = pathParts.length >= 2 ? pathParts[1] : '';

            console.log('Current area:', currentArea);
            console.log('Current controller:', currentController);

            // FIRST: Remove all active classes from all nav links and dropdown items
            document.querySelectorAll('.navbar-nav .nav-link, .dropdown-item').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelectorAll('.dropdown').forEach(d => {
                d.classList.remove('active-dropdown');
            });

            // For Organization area
            if (currentArea === 'organization') {
                // Dashboard link - active on root /organization or /organization/home
                if (currentPath === '/organization' || currentPath === '/organization/home') {
                    const dashboardLink = document.querySelector('.navbar-nav .nav-link[href*="/Organization"]');
                    if (dashboardLink && dashboardLink.getAttribute('href') !== '/Organization/Opportunity') {
                        dashboardLink.classList.add('active');
                    }
                }
                // Opportunity link - active on any other organization page
                else {
                    const opportunityLink = document.querySelector('.navbar-nav .nav-link[href*="/Organization/Opportunity"]');
                    if (opportunityLink) {
                        opportunityLink.classList.add('active');
                    }
                }
            }

            // For Volunteer area
            if (currentArea === 'volunteer') {
                // Opportunities link
                if (currentController === 'opportunities') {
                    const oppLink = document.querySelector('.navbar-nav .nav-link[href*="/Volunteer/Opportunities"]');
                    if (oppLink) oppLink.classList.add('active');
                }

                // Application link
                if (currentController === 'application') {
                    const appLink = document.querySelector('.navbar-nav .nav-link[href*="/Volunteer/Application"]');
                    if (appLink) appLink.classList.add('active');
                }

                // Organization dropdown
                if (currentController === 'organizations' || currentController === 'followedorgs') {
                    const orgDropdown = document.querySelector('.nav-item.dropdown > .dropdown-toggle');
                    if (orgDropdown) orgDropdown.classList.add('active');

                    // Also highlight the specific dropdown item
                    const dropdownItem = document.querySelector(`.dropdown-item[href*="/Volunteer/${currentController === 'organizations' ? 'Organizations' : 'FollowedOrgs'}"]`);
                    if (dropdownItem) dropdownItem.classList.add('active');
                }
            }

            // For Admin area
            if (currentArea === 'admin') {
                // Dashboard
                if (currentController === 'dashboard') {
                    const dashLink = document.querySelector('.navbar-nav .nav-link[href*="/Admin/Dashboard"]');
                    if (dashLink) dashLink.classList.add('active');
                }

                // Users
                if (currentController === 'users') {
                    const usersLink = document.querySelector('.navbar-nav .nav-link[href*="/Admin/Users"]');
                    if (usersLink) usersLink.classList.add('active');
                }

                // Reports
                if (currentController === 'report') {
                    const reportsLink = document.querySelector('.navbar-nav .nav-link[href*="/Admin/Report"]');
                    if (reportsLink) reportsLink.classList.add('active');
                }

                // Organization dropdown (Admin)
                if (currentController === 'organization') {
                    const orgDropdown = document.querySelector('.nav-item.dropdown > .dropdown-toggle');
                    if (orgDropdown) orgDropdown.classList.add('active');
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

