@model OpenHandsVolunteerPlatform.Models.Opportunity
@* By ANGEL *@
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Delete";
}

<!-- ww fix -->
<div class="container mt-4">
    <div class="page-header">
        <h1>Delete Opportunity</h1>
    </div>
    <div class="warning-text">Are you sure you want to delete this?</div>

    <hr />

    <dl class="row">
        <!-- ww fix -->
        @* <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Organization)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Organization.OrganizationId)
            </dd> *@
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Date)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StartTime)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StartTime)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndTime)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndTime)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Location)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Location)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VolunteersNeeded)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VolunteersNeeded)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ApplicationCloseDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ApplicationCloseDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>

    <form asp-action="Delete" method="post" onsubmit="return confirmDelete();">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OpportunityId" />
        <input type="hidden" asp-for="Status" />

        <a asp-action="Details" asp-route-id="@Model.OpportunityId" asp-route-status="@ViewBag.ReturnStatus" class="btn-back"><i class="bi bi-arrow-left"></i>Back to Details</a>
        <button type="submit" class="btn-delete">Delete</button>
    </form>
</div>

@* ww fix *@
<style>
    .page-header {
        margin-bottom: 1rem;
    }

    .page-header h1 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #3f4079;
        margin-bottom: 0.5rem;
    }

    .warning-text {
        font-size: 1rem;
        color: #b91c1c;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
    }

    .btn-back {
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
        margin-right: 1rem;
    }

    .btn-back:hover {
        color: #3f4079;
        text-decoration: underline;
    }

    .btn-delete {
        background: #dc2626;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-delete:hover {
        background: #b91c1c;
    }
</style>
