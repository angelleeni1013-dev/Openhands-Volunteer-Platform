@model OpenHandsVolunteerPlatform.ViewModels.OrganizationEditViewModel

@{
ViewData["Title"] = "Edit Organization";
}

<!-- Link to external CSS files -->
<link rel="stylesheet" href="~/css/OrgProfile.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/OrgEditProfile.css" asp-append-version="true" />
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="main-container">
    <div class="edit-container">
        <div class="edit-header">
            <h1>EDIT ORGANIZATION</h1>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OrganizationId" />
            <input type="hidden" asp-for="ExistingLogoPath" />
            <input type="hidden" asp-for="ExistingVerificationDocumentPath" />

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Organization Name -->
            <div class="form-section">
                <label asp-for="OrganizationName" class="form-label"></label>
                <input asp-for="OrganizationName" class="form-control" required />
                <span asp-validation-for="OrganizationName" class="text-danger"></span>
            </div>

            <!-- Organization Type -->
            <div class="form-section">
                <label class="form-label">ORGANIZATION TYPE</label>
                <!--ww fix-->
                <select asp-for="OrganizationType" class="form-select" name="OrganizationType">
                    <option value="">Select organization type</option>
                    <option value="Non-Profit">Non-Profit</option>
                    <option value="Charity">Charity</option>
                    <option value="Community">Community Organization</option>
                    <option value="Educational">Educational</option>
                    <option value="Healthcare">Healthcare</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <!-- Official Email -->
            <div class="form-section">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Organization Logo -->
            <div class="form-section">
                <label asp-for="LogoFile" class="form-label"></label>

                @if (!string.IsNullOrEmpty(Model.ExistingLogoPath))
                {
                    <div class="current-file">
                        <i class="bi bi-image"></i>
                        <span>Current logo: @System.IO.Path.GetFileName(Model.ExistingLogoPath)</span>
                    </div>
                }

                <div>
                    <label for="LogoFile" class="btn-upload">
                        <i class="bi bi-cloud-upload"></i> Upload
                    </label>
                    <input asp-for="LogoFile" type="file" accept="image/*" class="d-none" id="LogoFile" onchange="updateFileName(this, 'logo-name')" />
                    <span id="logo-name" class="file-name"></span>
                </div>
                <span asp-validation-for="LogoFile" class="text-danger"></span>
            </div>

            <!-- Official Phone Number -->
            <div class="form-section">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" required />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <!-- Organization Registration Certificate -->
            <div class="form-section">
                <label asp-for="VerificationDocumentFile" class="form-label"></label>

                @if (!string.IsNullOrEmpty(Model.ExistingVerificationDocumentPath))
                {
                    <div class="current-file">
                        <i class="bi bi-file-earmark-pdf"></i>
                        <span>Current: @System.IO.Path.GetFileName(Model.ExistingVerificationDocumentPath)</span>
                    </div>
                }

                <div>
                    <label for="VerificationDocumentFile" class="btn-upload">
                        <i class="bi bi-cloud-upload"></i> Upload
                    </label>
                    <input asp-for="VerificationDocumentFile" type="file" accept=".pdf,.jpg,.jpeg,.png" class="d-none" id="VerificationDocumentFile" onchange="updateFileName(this, 'doc-name')" />
                    <span id="doc-name" class="file-name"></span>
                </div>
                <span asp-validation-for="VerificationDocumentFile" class="text-danger"></span>
            </div>

            @* <!-- Password -->
            <div class="form-section">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <small class="text-muted">Leave blank to keep current password</small>
            </div> *@

            <!-- Mission Statement -->
            <div class="form-section">
                <label asp-for="Mission" class="form-label"></label>
                <textarea asp-for="Mission" class="form-textarea"></textarea>
                <span asp-validation-for="Mission" class="text-danger"></span>
            </div>

            @* <!-- Confirm Password -->
            <div class="form-section">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div> *@

            <hr />

            <!-- Terms and Conditions -->
            <div class="checkbox-group">
                <div class="checkbox-item">
                    <input asp-for="AcceptPrivacyPolicy" type="checkbox" />
                    <label asp-for="AcceptPrivacyPolicy">
                        <a href="javascript:void(0);" onclick="openPrivacyModal()">Privacy Policy</a>
                    </label>
                </div>
                <div class="checkbox-item">
                    <input asp-for="AcceptTermsConditions" type="checkbox" />
                    <label asp-for="AcceptTermsConditions">
                        <a href="javascript:void(0);" onclick="openTermsModal()">Terms & Conditions</a>
                    </label>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="@Url.Action("Index")" class="btn-discard">
                    <i class="bi bi-x-lg"></i> Discard Edits
                </a>
                <button type="submit" class="btn-save">
                    <i class="bi bi-check-lg"></i> SAVE CHANGES
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function updateFileName(input, displayId) {
        const fileName = input.files[0]?.name;
        document.getElementById(displayId).textContent = fileName || '';
    }

    function openPrivacyModal() {
        const modal = document.getElementById('privacyPolicyModal');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closePrivacyModal() {
        const modal = document.getElementById('privacyPolicyModal');
        modal.style.display = 'none';
        document.body.style.overflow = '';
    }
    function openTermsModal() {
        const modal = document.getElementById('termsModal');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeTermsModal() {
        const modal = document.getElementById('termsModal');
        modal.style.display = 'none';
        document.body.style.overflow = '';
    }
    // click outside to close
    document.addEventListener('click', function (e) {
        const modal = document.getElementById('privacyPolicyModal');
        if (e.target === modal) {
            closePrivacyModal();
        }
    });
    document.addEventListener('click', function (e) {
        const modal = document.getElementById('termsModal');
        if (e.target === modal) {
            closeTermsModal();
        }
    });
</script>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@await Html.PartialAsync("_PrivacyPolicyModal")
@await Html.PartialAsync("_TermsModal")