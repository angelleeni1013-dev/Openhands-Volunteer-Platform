@model OpenHandsVolunteerPlatform.ViewModels.VolunteerDirectoryViewModel
@using OpenHandsVolunteerPlatform.Models.Enums
@using OpenHandsVolunteerPlatform.ViewModels

@{
    ViewData["Title"] = "Volunteer Directory";
    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
}

<link rel="stylesheet" href="~/css/OrgVolunteerDirectory.css" asp-append-version="true" />

<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        
<div class="main-container">
    <!-- ww fix -->
    <!-- Breadcrumb -->
    @if (ViewBag.IsSpecificOpportunity == true)
    {
        <div class="breadcrumb" style="font-size: 0.85rem; margin-bottom: 1rem;">
            <a href="@Url.Action("Index", "Opportunity")" style="font-size: 0.85rem;">Opportunities</a>
            <i class="bi bi-chevron-right" style="font-size: 0.7rem;"></i>
            <a href="@Url.Action("Details", "Opportunity", new { id = ViewBag.CurrentOpportunityId })" style="font-size: 0.85rem;">@ViewBag.OpportunityTitle</a>
            <i class="bi bi-chevron-right" style="font-size: 0.7rem;"></i>
            <span style="font-size: 0.85rem;">Manage Volunteers</span>
        </div>
    }

    <!-- ww fix -->
    <!-- Page Header -->
    <h1 class="page-title">Volunteer Directory</h1>
    <p class="page-subtitle">Find volunteers ready to support community initiatives.</p>

    <!-- Stats Cards -->
    <div class="stats-container">
        <div class="stat-card">
            <div class="stat-value">@Model.TotalCount</div>
            <div class="stat-label">Total Volunteers</div>
        </div>
        <div class="stat-card high">
            <div class="stat-value">@Model.HighCount</div>
            <div class="stat-label">High Credit</div>
        </div>
        <div class="stat-card average">
            <div class="stat-value">@Model.AverageCount</div>
            <div class="stat-label">Average Credit</div>
        </div>
        <div class="stat-card low">
            <div class="stat-value">@Model.LowCount</div>
            <div class="stat-label">Low Credit</div>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="action-bar">
        <div class="search-wrapper">
            <i class="bi bi-search search-icon"></i>
            <input type="text" class="search-input" id="searchInput" placeholder="SEARCH" value="@currentSearch">
        </div>
        <a href="@Url.Action("Export", new { filter = currentFilter })" class="btn-export">
            <i class="bi bi-download"></i> Export
        </a>
    </div>

    <!-- By FY fixed -->
    <!-- Filter Pills -->
    <div class="filter-pills">
        <a href="@Url.Action("Index", new { opportunityId = ViewBag.CurrentOpportunityId, filter = "all", search = currentSearch })"
            class="filter-pill @(currentFilter == "all" ? "active" : "")">All</a>

        <a href="@Url.Action("Index", new { opportunityId = ViewBag.CurrentOpportunityId, filter = "high", search = currentSearch })"
            class="filter-pill @(currentFilter == "high" ? "active" : "")">High Credit</a>

        <a href="@Url.Action("Index", new { opportunityId = ViewBag.CurrentOpportunityId, filter = "average", search = currentSearch })"
            class="filter-pill @(currentFilter == "average" ? "active" : "")">Average Credit</a>

        <a href="@Url.Action("Index", new { opportunityId = ViewBag.CurrentOpportunityId, filter = "low", search = currentSearch })"
            class="filter-pill @(currentFilter == "low" ? "active" : "")">Low Credit</a>
    </div>

    <!-- Volunteers Table -->
    <div class="volunteers-table-container">
        @if (Model.Volunteers.Any())
        {
            <table class="volunteers-table" id="volunteersTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Joined Date</th>
                        <th>Credit Score</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- By FY fixed -->
                    @if (ViewBag.TableVolunteers != null && ((List<VolunteerDirectoryItemViewModel>)ViewBag.TableVolunteers).Any())
                    {
                        foreach (var volunteer in (List<VolunteerDirectoryItemViewModel>)ViewBag.TableVolunteers)
                        {
                            <tr data-volunteer-id="@volunteer.VolunteerId">
                                <td><strong>@volunteer.Name</strong></td>
                                <td>@volunteer.Email</td>
                                <td>@volunteer.JoinedDate.ToString("dd MMMM yyyy")</td>
                                <td>
                                    <span class="credit-badge @volunteer.CreditLevelClass">
                                        @volunteer.CreditLevelDisplay
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 0.5rem;">
                                        <button class="btn-action" onclick="viewProfile('@volunteer.VolunteerId')" title="View Profile">
                                            <i class="bi bi-file-text"></i>
                                        </button>
                                        <button class="btn-action" onclick="viewCreditHistory('@volunteer.VolunteerId')" title="View Credit History" style="background-color: #fef3c7;">
                                            <i class="bi bi-star-fill" style="color: #f59e0b;"></i>
                                        </button>
                                        @if (ViewBag.IsSpecificOpportunity == true)
                                        {
                                            <button class="btn-action" onclick="removeVolunteer('@volunteer.VolunteerId', '@volunteer.Name')" title="Remove from this opportunity" style="background-color: #fee2e2;">
                                                <i class="bi bi-person-x" style="color: #b91c1c;"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h3>No volunteers found</h3>
                <p>No volunteers match your search criteria.</p>
            </div>
        }
    </div>
</div>

<!-- Profile Modal -->
<div class="modal fade" id="profileModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Volunteer Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="profileModalBody">
                <!-- Content will be loaded dynamically -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Hidden field for anti-forgery token -->
@Html.AntiForgeryToken()

<!-- Bootstrap JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

<script>
    // Search functionality with debounce
    let searchTimeout;
    document.getElementById('searchInput').addEventListener('keyup', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            const searchTerm = this.value;
            const currentFilter = '@currentFilter';
            window.location.href = `@Url.Action("Index")?filter=${currentFilter}&search=${encodeURIComponent(searchTerm)}`;
        }, 500);
    });

    // View profile
    function viewProfile(volunteerId) {
        const modal = new bootstrap.Modal(document.getElementById('profileModal'));
        const modalBody = document.getElementById('profileModalBody');

        // Show loading
        modalBody.innerHTML = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        `;

        modal.show();

        // Fetch profile data
        fetch(`/Organization/VolunteerDirectory/Details/${volunteerId}`)
            .then(response => response.json())
            .then(data => {
                const volunteer = data.volunteer;
                const applications = data.applications;

                let applicationsHtml = '';
                if (applications && applications.length > 0) {
                    applicationsHtml = applications.map(app => `
                        <tr>
                            <td>${app.opportunity}</td>
                            <td>${new Date(app.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}</td>
                            <td><span class="badge ${getStatusBadgeClass(app.status)}">${getApplicationStatusText(app.status)}</span></td>
                            <td><span class="badge ${getAttendanceBadgeClass(app.attendanceStatus)}">${getAttendanceStatusText(app.attendanceStatus)}</span></td>
                        </tr>
                    `).join('');
                } else {
                    applicationsHtml = '<tr><td colspan="4" class="text-center">No applications yet</td></tr>';
                }

                modalBody.innerHTML = `
                    <div class="profile-section">
                        <div class="profile-section-title">Personal Information</div>
                        <div class="profile-info-row">
                            <span class="profile-info-label">Name:</span>
                            <span class="profile-info-value">${volunteer.name}</span>
                        </div>
                        <div class="profile-info-row">
                            <span class="profile-info-label">Email:</span>
                            <span class="profile-info-value">${volunteer.email}</span>
                        </div>
                        <div class="profile-info-row">
                            <span class="profile-info-label">Phone:</span>
                            <span class="profile-info-value">${volunteer.phone}</span>
                        </div>
                        <div class="profile-info-row">
                            <span class="profile-info-label">Age:</span>
                            <span class="profile-info-value">${volunteer.age}</span>
                        </div>
                        <div class="profile-info-row">
                            <span class="profile-info-label">Joined:</span>
                            <span class="profile-info-value">${new Date(volunteer.joinedDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
                        </div>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section-title">Credit Score</div>
                        <div class="profile-stats">
                            <div class="profile-stat">
                                <div class="profile-stat-value">${volunteer.completedCount}</div>
                                <div class="profile-stat-label">Completed</div>
                            </div>
                            <div class="profile-stat">
                                <div class="profile-stat-value">${volunteer.totalHours}</div>
                                <div class="profile-stat-label">Hours</div>
                            </div>
                            <div class="profile-stat">
                                <div class="profile-stat-value">${volunteer.noShowCount}</div>
                                <div class="profile-stat-label">No-Shows</div>
                            </div>
                        </div>
                        <div style="margin-top: 1rem; text-align: center;">
                            <span class="credit-badge ${getCreditBadgeClass(volunteer.creditLevel)}">
                                ${getCreditLevelDisplay(volunteer.creditLevel)}
                            </span>
                        </div>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section-title">Application History</div>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Opportunity</th>
                                    <th>Date</th>
                                    <th>Application Status</th>
                                    <th>Attendance Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${applicationsHtml}
                            </tbody>
                        </table>
                    </div>
                `;
            })
            .catch(error => {
                console.error('Error:', error);
                modalBody.innerHTML = `
                    <div class="alert alert-danger">
                        Error loading profile. Please try again.
                    </div>
                `;
            });
    }

    function getApplicationStatusText(status) {
        switch (status) {
            case 1: return 'Applied';
            case 2: return 'Withdrawn';
            case 3: return 'Removed';
            case 4: return 'Waitlist';
            default: return 'Unknown';
        }
    }

    function getAttendanceStatusText(attendanceStatus) {
        switch (attendanceStatus) {
            case 1: return 'Pending';
            case 2: return 'Present';
            case 3: return 'NoShow';
            default: return 'Unknown';
        }
    }

    function getStatusBadgeClass(status) {
        switch(status) {
            case 1: return 'bg-success';
            case 2: return 'bg-warning text-dark';
            case 3: return 'bg-danger';
            case 4: return 'bg-secondary';
            default: return 'bg-secondary';
        }
    }

    function getAttendanceBadgeClass(attendanceStatus) {
        switch(attendanceStatus) {
            case 1: return 'bg-secondary';
            case 2: return 'bg-success';
            case 3: return 'bg-danger';
            default: return 'bg-secondary';
        }
    }

    function getCreditBadgeClass(level) {
        switch(level) {
            case 3: return 'credit-high'; // Core
            case 2: return 'credit-average'; // Growing
            case 1: return 'credit-low'; // Inactive
            default: return 'credit-unknown';
        }
    }

    function getCreditLevelDisplay(level) {
        switch(level) {
            case 3: return 'HIGH';
            case 2: return 'AVERAGE';
            case 1: return 'LOW';
            default: return 'UNKNOWN';
        }
    }

    // View credit history
    function viewCreditHistory(volunteerId) {
        const modal = new bootstrap.Modal(document.getElementById('creditHistoryModal'));
        const modalBody = document.getElementById('creditHistoryModalBody');

        // Show loading
        modalBody.innerHTML = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        `;

        modal.show();

        // Fetch credit history
        fetch(`/Organization/VolunteerDirectory/CreditHistory/${volunteerId}`)
            .then(response => response.text())
            .then(html => {
                modalBody.innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                modalBody.innerHTML = `
                    <div class="alert alert-danger">
                        Error loading credit history. Please try again.
                    </div>
                `;
            });
    }

    // Remove volunteer from opportunity
    function removeVolunteer(volunteerId, volunteerName) {
        const opportunityId = '@ViewBag.CurrentOpportunityId';

        if (!opportunityId) {
            alert('Cannot remove: This is the main volunteer directory, not a specific opportunity.');
            return;
        }

        if (confirm(`Are you sure you want to remove ${volunteerName} from this opportunity?`)) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/Organization/VolunteerDirectory/RemoveVolunteer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({
                    volunteerId: volunteerId,
                    opportunityId: opportunityId
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(`${volunteerName} has been removed from this opportunity.`);
                    // Reload the page to refresh the list
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error removing volunteer. Please try again.');
            });
        }
    }
</script>

<!-- Credit History Modal -->
<div class="modal fade" id="creditHistoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div id="creditHistoryModalBody">
                <!-- Content will be loaded dynamically -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

