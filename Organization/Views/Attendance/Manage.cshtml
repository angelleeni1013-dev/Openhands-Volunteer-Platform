@model OpenHandsVolunteerPlatform.ViewModels.ManageAttendanceViewModel
@using OpenHandsVolunteerPlatform.Models.Enums

@{
    ViewData["Title"] = $"Manage Attendance - {Model.OpportunityTitle}";
}

<link rel="stylesheet" href="~/css/OrgManageAttendance.css" asp-append-version="true" />

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div class="main-container">
        <!-- ww fix -->
        <!-- Breadcrumb -->
        <div class="breadcrumb" style="font-size: 0.85rem; margin-bottom: 1rem;">
            <a href="@Url.Action("Index", "Opportunity")" style="font-size: 0.85rem;">Opportunities</a>
            <i class="bi bi-chevron-right" style="font-size: 0.7rem;"></i>
            <a href="@Url.Action("Details", "Opportunity", new { id = Model.OpportunityId })" style="font-size: 0.85rem;">@Model.OpportunityTitle</a>
            <i class="bi bi-chevron-right" style="font-size: 0.7rem;"></i>
            <span style="font-size: 0.85rem;">Manage Attendance</span>
        </div>

        <!-- ww fix -->
        <h1 class="page-title">Manage Attendance</h1>

        <div class="event-info">
            <div class="event-info-item"><i class="bi bi-calendar-event"></i><strong>@Model.OpportunityTitle</strong></div>
            <div class="event-info-item"><i class="bi bi-calendar3"></i>@Model.EventDate.ToString("dd MMM yyyy")</div>
            <div class="event-info-item"><i class="bi bi-clock"></i>@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</div>
            <div class="event-info-item"><i class="bi bi-geo-alt"></i>@Model.Location</div>
        </div>

        <div class="search-section">
            <div class="search-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="search-input" id="searchInput" placeholder="SEARCH">
            </div>
        </div>

        <div class="volunteers-table">
            <div class="select-all-container">
                <label class="select-all-checkbox">
                    <input type="checkbox" id="selectAll" class="checkbox-custom">
                    <span>Select All Volunteers</span>
                </label>
            </div>

            <table id="attendanceTable">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>CHECK-IN TIME</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Volunteers.Count; i++)
                    {
                        var volunteer = Model.Volunteers[i];
                        var isPresent = volunteer.AttendanceStatus == AttendanceStatus.Present;
                        var appId = volunteer.ApplicationId;
                        <tr>
                            <td>@(i + 1)</td>
                            <td><strong>@volunteer.VolunteerName</strong></td>
                            <td>@volunteer.Email</td>
                            <td id="time-@appId">
                                @if (volunteer.CheckInTime.HasValue)
                                {
                                    <span class="check-in-time">@volunteer.CheckInTime.Value.ToString("HH:mm:ss")</span>
                                }
                                else if (isPresent)
                                {
                                    <span class="check-in-time empty">-</span>
                                }
                                else
                                {
                                    <span class="check-in-time empty">-</span>
                                }
                            </td>
                            <td>
                                <input type="checkbox"
                                       class="checkbox-custom attendance-cb"
                                       data-id="@appId"
                                       @(isPresent ? "checked" : "")>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Volunteers.Any())
            {
                <div class="empty-state"><i class="bi bi-people"></i><h3>No volunteers registered</h3></div>
            }
        </div>

        <div class="action-buttons">
            <a href="@Url.Action("Details", "Opportunity", new { id = Model.OpportunityId })" class="btn-cancel">Cancel</a>
            <button class="btn-submit" id="submitBtn">Submit Attendance</button>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Global variable to track changes
        let changesList = [];

        $(document).ready(function() {
            // When checkbox changes
            $('.attendance-cb').on('change', function() {
                const id = $(this).data('id');
                const isChecked = $(this).is(':checked');
                const timeCell = $('#time-' + id);

                // Get existing check-in time from the timeCell (if any)
                const existingTimeElement = timeCell.find('.check-in-time');
                const existingTime = existingTimeElement.length > 0 && existingTimeElement.text().trim() !== '-'
                    ? existingTimeElement.text().trim()
                    : null;

                if (isChecked) {
                    // If already checked and has existing time, keep it
                    // If newly checked, set current time
                    let timeString;
                    if (existingTime) {
                        timeString = existingTime;
                    } else {
                        const now = new Date();
                        timeString = now.toTimeString().split(' ')[0];
                    }
                    timeCell.html('<span class="check-in-time">' + timeString + '</span>');

                    const existing = changesList.find(x => x.applicationId === id);
                    if (existing) {
                        existing.attendanceStatus = 'Present';
                        existing.checkInTime = timeString;
                    } else {
                        changesList.push({
                            applicationId: id,
                            attendanceStatus: 'Present',
                            checkInTime: timeString
                        });
                    }
                } else {
                    timeCell.html('<span class="check-in-time empty">-</span>');
                    const existing = changesList.find(x => x.applicationId === id);
                    if (existing) {
                        existing.attendanceStatus = 'Pending';
                        existing.checkInTime = null;
                    } else {
                        changesList.push({
                            applicationId: id,
                            attendanceStatus: 'Pending',
                            checkInTime: null
                        });
                    }
                }

                updateSelectAll();
            });

            // Select All - FIX: Don't change time for already checked volunteers
            $('#selectAll').on('change', function() {
                const isChecked = $(this).is(':checked');
                $('.attendance-cb').each(function() {
                    const currentChecked = $(this).is(':checked');
                    // Only trigger change if the state is different
                    if (currentChecked !== isChecked) {
                        $(this).prop('checked', isChecked).trigger('change');
                    }
                });
            });

            // Update Select All state
            function updateSelectAll() {
                const total = $('.attendance-cb').length;
                const checked = $('.attendance-cb:checked').length;
                const selectAll = $('#selectAll');

                if (total === 0) return;
                if (checked === total) {
                    selectAll.prop('checked', true).prop('indeterminate', false);
                } else if (checked === 0) {
                    selectAll.prop('checked', false).prop('indeterminate', false);
                } else {
                    selectAll.prop('indeterminate', true);
                }
            }

            // Search
            $('#searchInput').on('keyup', function() {
                const term = $(this).val().toLowerCase();
                $('#attendanceTable tbody tr').each(function() {
                    const name = $(this).find('td:eq(1)').text().toLowerCase();
                    const email = $(this).find('td:eq(2)').text().toLowerCase();
                    if (name.includes(term) || email.includes(term)) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });

            // Submit button
            $('#submitBtn').on('click', function() {
                if (changesList.length === 0) {
                    alert('No changes to submit!');
                    return;
                }

                const btn = $(this);
                btn.html('<i class="bi bi-hourglass-split"></i> Submitting...').prop('disabled', true);

                fetch('/Organization/Attendance/Update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(changesList)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Attendance submitted successfully!');
                        window.location.href = '@Url.Action("Details", "Opportunity", new { id = Model.OpportunityId })';
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Error: ' + error);
                })
                .finally(() => {
                    btn.html('<i class="bi bi-check-lg"></i> Submit Attendance').prop('disabled', false);
                });
            });

            // Initialize already checked boxes with saved check-in times
            $('.attendance-cb:checked').each(function() {
                const id = $(this).data('id');
                const timeCell = $('#time-' + id);
                const savedTime = timeCell.find('.check-in-time').text().trim();

                changesList.push({
                    applicationId: id,
                    attendanceStatus: 'Present',
                    checkInTime: savedTime !== '-' ? savedTime : null
                });
            });

            console.log('Initial changesList:', changesList);
        });
    </script>
</body>
</html>